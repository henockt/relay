# Server
PORT=8080

# Database
DB_USER=postgres
DB_PASSWORD=password
DB_NAME=relay
DATABASE_URL=postgres://user:password@host:5432/relay?sslmode=require

# Auth
JWT_SECRET=

# Google OAuth (https://console.cloud.google.com)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URL=https://your-app.example.com/api/auth/google/callback

# Email (SendGrid)
SMTP_DOMAIN=your-app.example.com
SENDGRID_API_KEY=
WEBHOOK_SECRET=

# App URLs
FRONTEND_URL=https://your-app.example.com
NEXT_PUBLIC_API_URL=https://your-app.example.com

# Cookies
SECURE_COOKIES=true
